# ============================================================
# Credenciais das contas Bling
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA versione o arquivo .env (ele já está no .gitignore).
#
# Como obter client_id e client_secret:
#   1. Acesse https://developer.bling.com.br
#   2. Crie um aplicativo e copie as credenciais geradas.
#   3. Configure a Redirect URL do app para qualquer URL
#      (ex: https://localhost) — só é usada no oauth_setup.py.
# ============================================================

# --- Conta 1 ---
BLING_CONTA1_CLIENT_ID=seu_client_id_aqui
BLING_CONTA1_CLIENT_SECRET=seu_client_secret_aqui

# --- Conta 2 ---
BLING_CONTA2_CLIENT_ID=seu_client_id_aqui
BLING_CONTA2_CLIENT_SECRET=seu_client_secret_aqui

# Adicione mais contas conforme necessário (CONTA3, CONTA4, ...)
